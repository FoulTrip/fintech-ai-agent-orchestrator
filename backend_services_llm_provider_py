import os
from typing import Dict

class LLMProvider:
    """
    Capa de abstracción para LLMs. Soporta modo Mock para desarrollo.
    """
    def __init__(self):
        self.use_mock = os.getenv("USE_MOCK_IA", "true").lower() == "true"

    async def get_completion(self, prompt: str, system_instruction: str) -> str:
        if self.use_mock:
            return self._get_mock_response(system_instruction)
        
        # Aquí iría la integración real con OpenAI/Anthropic
        return "Respuesta real de la IA (Requiere API Key configurada)"

    def _get_mock_response(self, system_instruction: str) -> str:
        if "Technical" in system_instruction:
            return "Análisis Técnico: El RSI está en 35, indicando sobreventa. Soporte fuerte en $42,000."
        if "Fundamental" in system_instruction:
            return "Análisis Fundamental: Los recientes datos de inflación sugieren una pausa en las tasas."
        if "Sentiment" in system_instruction:
            return "Sentimiento: El índice de Miedo y Codicia está en 65 (Codicia). Redes sociales optimistas."
        return "Análisis general: El mercado muestra una tendencia lateral con baja volatilidad."
