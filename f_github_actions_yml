        run: echo "Autenticando con Google Cloud SDK..."
      - name: Build & Push Images
        run: |
          echo "Building Docker images for GCR..."
          echo "Pushing to gcr.io/fintech-ai-agent-orchestrator/app..."
      - name: Cloud Run Deploy
        run: echo "Desplegando en Google Cloud Run..."